# Aether Application Configuration
# Copy this file to .env and fill in values for local development.
# For deployed environments, set these same variables in your platform (Vercel, etc.).

# App Identity (REQUIRED - Must be unique per app!)
NUXT_PUBLIC_APP_ID=
NUXT_PUBLIC_APP_NAME=

# Query Server
NUXT_PUBLIC_QUERY_SERVER_ADDRESS=

# Auth0 (required for login)
# See README "Environment variables" for details.
NUXT_PUBLIC_AUTH0_ISSUER_BASE_URL=https://auth.lovelace.ai
NUXT_PUBLIC_AUTH0_CLIENT_ID=
NUXT_PUBLIC_AUTH0_CLIENT_SECRET=
NUXT_PUBLIC_AUTH0_AUDIENCE=queryserver:api
NUXT_PUBLIC_COOKIE_SECRET=

# Leave empty when using Auth0 (otherwise auth is bypassed)
NUXT_PUBLIC_USER_NAME=

# Firebase Configuration (for preferences storage)
# Get these from your Firebase project settings
# NUXT_PUBLIC_FIREBASE_API_KEY=
# NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NUXT_PUBLIC_FIREBASE_PROJECT_ID=
# NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NUXT_PUBLIC_FIREBASE_APP_ID=
